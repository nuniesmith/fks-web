# ──────────────────────────────────────────────────────────────
# FKS SvelteKit WebUI — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env` and adjust values as needed.
# Variables prefixed with PUBLIC_ are exposed to client-side code
# via SvelteKit's $env/static/public module.
# ──────────────────────────────────────────────────────────────

# The backend URL used by the Vite dev proxy and SSR fetch calls.
# In production (Docker), this points to the internal service name.
PUBLIC_API_URL=http://localhost:8000
PUBLIC_JANUS_URL=http://localhost:7000

# SSE reconnect interval (ms) — how long to wait before reconnecting
# a dropped Server-Sent Events connection.
PUBLIC_SSE_RECONNECT_MS=5000

# Default polling interval (ms) — suggested interval for non-SSE
# periodic data fetching (used as a default by consumers of createPoll).
PUBLIC_POLL_INTERVAL_MS=30000

# API base URL — leave empty to use relative URLs (same origin).
# Set this when the data service lives on a different host/port.
PUBLIC_API_BASE_URL=
